# =============================================================================
# HOMELAB — Configuration
# Copier ce fichier en .env et remplir les valeurs
# NE JAMAIS versionner le fichier .env
# =============================================================================

# -----------------------------------------------------------------------------
# SYSTÈME
# -----------------------------------------------------------------------------
# Utilisateur Linux qui exécute les services (créé par setup.sh)
SYSTEM_USER=homelab

# UID/GID de cet utilisateur (laisser 1000 pour le premier user du système)
PUID=1000
PGID=1000

# Timezone (https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
TZ=Europe/Paris

# -----------------------------------------------------------------------------
# RÉSEAU / DOMAINE
# -----------------------------------------------------------------------------
# Ton domaine principal (ex: mondomaine.com)
DOMAIN=yourdomain.com

# IP LAN du serveur (utilisé par Plex pour le widget)
SERVER_LAN_IP=192.168.1.100

# -----------------------------------------------------------------------------
# CHEMINS
# Répertoires DATA sur le serveur hôte (absolus)
# setup.sh les crée automatiquement si inexistants
# -----------------------------------------------------------------------------
# Répertoire principal des médias (films, séries, animes)
MEDIA_DIR=/home/homelab/media

# Répertoire des téléchargements
DOWNLOADS_DIR=/home/homelab/downloads

# Répertoires médias supplémentaires (disques USB, NAS, etc.)
# Décommenter et adapter selon ta configuration
# USB_MEDIA_DIR_1=/mnt/usb1/media
# USB_MEDIA_DIR_2=/mnt/usb2/media

# -----------------------------------------------------------------------------
# PLEX
# -----------------------------------------------------------------------------
# Token de claim Plex (obtenir sur https://www.plex.tv/claim/ — valide 4 min)
# Laisser vide si le serveur Plex est déjà configuré
PLEX_CLAIM=

# -----------------------------------------------------------------------------
# NTFY — Notifications de l'updater (optionnel)
# Si renseignés, updater/updater.sh envoie une notif de succès/échec à chaque run.
# Créer un token write-only sur le serveur ntfy :
#   docker exec ntfy ntfy user add homelab-updater        # (NTFY_PASSWORD=... en env)
#   docker exec ntfy ntfy access homelab-updater homelab write-only
#   docker exec ntfy ntfy token add homelab-updater       # → copier le tk_... ici
# -----------------------------------------------------------------------------
NTFY_URL=
NTFY_TOKEN=

# -----------------------------------------------------------------------------
# HOMEPAGE — Clés API des widgets
# Ces clés sont générées APRÈS le premier démarrage de chaque service
# Voir README.md pour les instructions de récupération
# -----------------------------------------------------------------------------
HOMEPAGE_PLEX_TOKEN=
HOMEPAGE_TAUTULLI_KEY=
HOMEPAGE_SEERR_KEY=
HOMEPAGE_SONARR_KEY=
HOMEPAGE_RADARR_KEY=
HOMEPAGE_PROWLARR_KEY=
HOMEPAGE_DUPLICATI_TOKEN=

# Credentials UI des services
# Ces valeurs sont générées et écrites automatiquement par setup.sh.
# Sur une installation manuelle, définir des mots de passe forts.
HOMEPAGE_RDTCLIENT_USERNAME=admin
HOMEPAGE_RDTCLIENT_PASSWORD=changeme

HOMEPAGE_PYLOAD_USERNAME=pyload
HOMEPAGE_PYLOAD_PASSWORD=changeme

# Email + mot de passe du compte admin Nginx Proxy Manager
# setup.sh génère ces valeurs. Sur une install manuelle :
# 1. Se connecter à NPM avec admin@example.com / changeme
# 2. Changer l'email et le mot de passe dans NPM pour les valeurs ci-dessous
# 3. Le widget Homepage utilisera alors ces credentials via l'API NPM
HOMEPAGE_NPM_EMAIL=admin@yourdomain.com
HOMEPAGE_NPM_PASSWORD=changeme

# -----------------------------------------------------------------------------
# HOMEPAGE — Apparence
# -----------------------------------------------------------------------------
HOMEPAGE_ALLOWED_HOSTS=home.yourdomain.com

# Localisation pour le widget météo OpenMeteo
HOMEPAGE_WEATHER_LABEL=Ma Ville
HOMEPAGE_WEATHER_LATITUDE=48.8566
HOMEPAGE_WEATHER_LONGITUDE=2.3522
